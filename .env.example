# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://ocal:ocal@localhost:5432/ocal

# ── Redis (for BullMQ job queue) ─────────────────────────
REDIS_URL=redis://localhost:6379

# ── Authentication ───────────────────────────────────────
# REQUIRED: min 16 chars — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-64-char-string
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ADMIN_EMAILS=admin@example.com

# ── LLM (for smart field mapping — both optional) ───────
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# ── CKAN / ODATA ────────────────────────────────────────
CKAN_BASE_URL=https://www.odata.org.il
ODATA_API_KEY=

# ── App ──────────────────────────────────────────────────
PORT=3001
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info
NODE_ENV=development
