{
  "name": "ocal",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "server",
    "client",
    "shared",
    "extension"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "dev:ext": "npm run dev --workspace=extension",
    "build": "npm run build --workspace=shared && npm run build --workspace=client && npm run build --workspace=server",
    "build:ext": "npm run build --workspace=extension",
    "migrate": "npm run migrate --workspace=server",
    "migrate:rollback": "npm run migrate:rollback --workspace=server",
    "migrate:unlock": "npm run migrate:unlock --workspace=server",
    "backfill:search-vectors": "npm run backfill:search-vectors --workspace=server",
    "drop:coi": "npm run drop:coi --workspace=server",
    "seed": "npm run seed --workspace=server",
    "worker": "npm run worker --workspace=server"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0"
  }
}
